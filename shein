            if (countdownSeconds <= 0) return;
            countdownSeconds--;
            var m = Math.floor(countdownSeconds / 60);
            var s = countdownSeconds % 60;
            countdownEl.textContent = m + ':' + (s < 10 ? '0' : '') + s;
        }
        var countdownInterval = null;

        // ===== DOLLAR COUNTER =====
        var dollarBase = 847500;
