            dollarBase += Math.floor(Math.random() * 80) + 10;
            dollarEl.textContent = '$' + dollarBase.toLocaleString();
        }
        var dollarInterval = null;

        // ===== NOTIFICATION TOASTS =====
        var notifData = [
            {n:'Olivia M.',a:'$5',t:'cashed out after completing 1 deal'},
            {n:'Mia R.',a:'$100',t:'cashed out after completing 2 deals'},
            {n:'Sophie T.',a:'$5',t:'cashed out after completing 1 deal'},
            {n:'Emma L.',a:'$250',t:'cashed out after completing 3 deals'},
            {n:'Ava P.',a:'$100',t:'cashed out after completing 2 deals'},
            {n:'Charlotte K.',a:'$500',t:'cashed out after completing 4 deals'},
            {n:'Amelia W.',a:'$5',t:'cashed out after completing 1 deal'},
