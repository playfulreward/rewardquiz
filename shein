        var notifZone = document.getElementById('notifZone');
        var notifIdx = 0;
        var notifActive = false;
        var times = ['just now','2s ago','5s ago','just now','1s ago','3s ago','just now','4s ago','2s ago','just now','1s ago','3s ago','just now','2s ago','6s ago'];

        function showNotif() {
            if (!notifActive) return;
            var item = notifData[notifIdx % notifData.length];
            var time = times[notifIdx % times.length];
            notifIdx++;
            var toast = document.createElement('div');
            toast.className = 'notif-toast';
