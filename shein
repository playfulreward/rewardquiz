                '<div class="notif-time">' + time + '</div>';
            var old = notifZone.querySelector('.notif-toast');
            if (old) {
                old.classList.add('leaving');
                setTimeout(function() {
                    if (old.parentNode) old.parentNode.removeChild(old);
                    notifZone.appendChild(toast);
                }, 300);
            } else {
                notifZone.appendChild(toast);
            }
            setTimeout(function() {
                toast.classList.add('leaving');
                setTimeout(function() { if (toast.parentNode) toast.parentNode.removeChild(toast); }, 300);
            }, 3500);
        }
        function startNotifs() {
            if (notifActive) return;
            notifActive = true;
            setTimeout(showNotif, 1500);
            (function scheduleNext() {
                var delay = 4000 + Math.random() * 2000;
                setTimeout(function() { if (notifActive) { showNotif(); scheduleNext(); } }, delay);
