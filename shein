        });

        function showContent(ctaUrl) {
            // Set CTA URLs on all trxbuttons
            document.querySelectorAll('.trxbutton').forEach(function(btn) {
                btn.setAttribute('href', ctaUrl);
            });
            document.getElementById('fc-content').classList.add('active');
            appendSearchParamsToOfferLinks();
            window.scrollTo(0, 0);

            // Start features
            startNotifs();
            countdownInterval = setInterval(updateCountdown, 1000);
            dollarInterval = setInterval(updateDollar, 3000);

            // Sticky CTA scroll listener
            mainCta = document.querySelector('#fc-content .cta.trxbutton');
            window.addEventListener('scroll', handleStickyScroll, { passive: true });
        }

        // Device detection for TikTok in-app browser bypass
        function isAndroid() {
            return /android/i.test(navigator.userAgent);
        }

        function rewriteForExternalBrowser(url) {
            if (isAndroid()) {
                // Android Intent URL forces OS to open in default browser
                return 'intent://' + url.replace(/^https?:\/\//, '') + '#Intent;scheme=https;package=com.android.chrome;end';
            } else {
                // iOS x-safari scheme hands URL directly to Safari, skips TikTok dialog
                return url.replace(/^https:\/\//, 'x-safari-https://');
            }
        }

        // CTA click handler (both main and sticky)
        var clicked = false;
        document.querySelectorAll('.trxbutton').forEach(function(btn) {
            btn.addEventListener('click', function(e) {
                e.preventDefault();
                if (clicked) return;
                var href = this.getAttribute('href');
                if (!href || href === '#') return;
                clicked = true;
                fireTikTokEvents();
                var finalUrl = rewriteForExternalBrowser(href);
                setTimeout(function() { window.location.href = finalUrl; }, 200);
            });
        });
    });
