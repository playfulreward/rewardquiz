            var pairs = [];
            forwarded.forEach(function(key) {
                if (urlParams.has(key)) {
                    pairs.push(key + '=' + encodeURIComponent(urlParams.get(key)));
                }
            });
            if (pairs.length === 0) return;
            var extra = pairs.join('&');
            document.querySelectorAll('.trxbutton').forEach(function(button) {
                var href = button.getAttribute('href');
                if (href && href !== '#') {
                    // If the base URL already ends with &s1= or ?s1= (blank), replace it
                    href = href.replace(/[&?]s1=$/, '');
                    var separator = href.indexOf('?') !== -1 ? '&' : '?';
                    button.setAttribute('href', href + separator + extra);
                }
            });
        }

